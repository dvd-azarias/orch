[Unit]
Description=Orch Celery Worker (Component Generate File)
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=orch
Group=orch
WorkingDirectory=/opt/orch

EnvironmentFile=/etc/orch/orch.env
Environment=PYTHONUNBUFFERED=1
Environment=PYTHONPATH=/opt/orch
Environment=ORCH_QUEUE_PROFILE=prod
Environment=CELERY_ENABLED=true
Environment=CELERY_BEAT_DISPATCH_ENABLED=false
Environment=CELERY_BEAT_HEARTBEAT_ENABLED=false
Environment=CELERY_GENERATE_FILE_ENABLED=true
Environment=CELERY_GENERATE_FILE_SCAN_ENABLED=true
Environment=CELERY_GENERATE_FILE_RUN_QUEUE=orch_component_generate_file_run
Environment=CELERY_GENERATE_FILE_SCAN_QUEUE=orch_component_generate_file_scan

ExecStart=/opt/orch/.venv/bin/celery -A app.core.celery_app:celery_app worker \
  --hostname=orch-celery-generate-file-worker@136_01 \
  --loglevel=INFO \
  --pool=prefork \
  --queues=orch_component_generate_file_run,orch_component_generate_file_scan \
  --concurrency=4 \
  --prefetch-multiplier=1 \
  -Ofair \
  --max-tasks-per-child=1000 \
  --max-memory-per-child=350000 \
  --without-gossip \
  --without-mingle

Restart=always
RestartSec=5
TimeoutStopSec=180
KillMode=mixed

NoNewPrivileges=true
PrivateTmp=true
ProtectSystem=full
ProtectHome=true
LimitNOFILE=65535

[Install]
WantedBy=multi-user.target
