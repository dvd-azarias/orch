# Core
CELERY_ENABLED=true
WORKFLOW_V2_ENABLED=true
WORKFLOW_V2_EXECUTE_M2=true
ORCH_QUEUE_PROFILE=prod

# Broker/Backend (exemplos)
CELERY_BROKER_URL=amqp://admin:admin@127.0.0.1:5672//
CELERY_RESULT_BACKEND=redis://:redis-pass@127.0.0.1:6379/0

# DB / workspace fallback (ajustar ao ambiente)
DATABASE_HOST=127.0.0.1
DATABASE_PORT=5432
DATABASE_NAME=target_core
DATABASE_USER=postgres
DATABASE_PASSWORD=postgres
DATABASE_SCHEMA=ws_ba7eb0ec-e565-447c-8c11-8f870cf72a60
ORCH_DEFAULT_WORKSPACE_UUID=ba7eb0ec-e565-447c-8c11-8f870cf72a60

# Workflow queues (legacy/runtime)
CELERY_DISPATCH_QUEUE=orch_dispatch
CELERY_EXECUTE_QUEUE=orch_execute
CELERY_HEARTBEAT_QUEUE=orch_heartbeat

# FileApp queues (isoladas)
CELERY_FILEAPP_INGEST_ENABLED=true
CELERY_S3_FILES_INGEST_QUEUE=orch_fileapp_ingest_events
CELERY_SOURCE_LIST_INGEST_QUEUE=orch_fileapp_source_list_ingest

# Generate File queues (isoladas)
CELERY_GENERATE_FILE_ENABLED=true
CELERY_GENERATE_FILE_SCAN_ENABLED=true
CELERY_GENERATE_FILE_SCAN_INTERVAL_SECONDS=10
CELERY_GENERATE_FILE_RUN_QUEUE=orch_component_generate_file_run
CELERY_GENERATE_FILE_SCAN_QUEUE=orch_component_generate_file_scan

# Docs access control (interno/VPN permitido; externo bloqueado)
DOCS_ACCESS_CONTROL_ENABLED=true
DOCS_INTERNAL_CIDRS=10.1.20.0/24,10.100.105.0/24,127.0.0.1/32,::1/128
DOCS_TRUSTED_PROXY_CIDRS=10.1.20.130/32
DOCS_BLOCKED_HOSTS=orch.otima.digital
